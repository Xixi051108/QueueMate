{
  "info": {
    "_postman_id": "6c4f9cf8-6fb6-4dc1-8cb7-9e8b5fa1a001",
    "name": "QueueMate API",
    "description": "QueueMate API functional and security checks.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/v1/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('health returns 200', () => pm.response.to.have.status(200));",
              "pm.test('service is UP', () => pm.expect(pm.response.json().data.status).to.eql('UP'));"
            ]
          }
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register dynamic user",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('registerUsername', 'qm_' + Date.now());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('register returns 201', () => pm.response.to.have.status(201));",
                  "pm.test('registered role is USER', () => pm.expect(body.data.role).to.eql('USER'));",
                  "pm.test('registered username matches request', () => pm.expect(body.data.username).to.eql(pm.collectionVariables.get('registerUsername')));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{registerUsername}}\",\n  \"password\": \"{{registerPassword}}\",\n  \"displayName\": \"Postman User\",\n  \"phone\": \"13800007777\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/register"
          }
        },
        {
          "name": "Login registered user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('login returns 200', () => pm.response.to.have.status(200));",
                  "pm.test('token type is Bearer', () => pm.expect(body.data.tokenType).to.eql('Bearer'));",
                  "pm.test('token is returned', () => pm.expect(body.data.token).to.be.a('string').and.not.empty);",
                  "pm.environment.set('token', body.data.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{registerUsername}}\",\n  \"password\": \"{{registerPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        },
        {
          "name": "Get current user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('current user returns 200', () => pm.response.to.have.status(200));",
                  "pm.test('identity matches login user', () => pm.expect(body.data.username).to.eql(pm.collectionVariables.get('registerUsername')));",
                  "pm.test('current user is active', () => pm.expect(body.data.status).to.eql('ACTIVE'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/v1/auth/me"
          }
        },
        {
          "name": "Reject wrong password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('wrong password returns 401', () => pm.response.to.have.status(401));",
                  "pm.test('credential error is stable', () => pm.expect(body.code).to.eql('AUTH_CREDENTIALS_INVALID'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"password\": \"WrongPass123\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        },
        {
          "name": "Reject missing token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('missing token returns 401', () => pm.response.to.have.status(401));",
                  "pm.test('unauthorized code is stable', () => pm.expect(body.code).to.eql('AUTH_UNAUTHORIZED'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/auth/me"
          }
        }
      ]
    },
    {
      "name": "Venues",
      "item": [
        {
          "name": "List active venues publicly",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('venue list returns 200', () => pm.response.to.have.status(200));",
                  "pm.test('venue list is an array', () => pm.expect(body.data).to.be.an('array'));",
                  "pm.test('all returned venues are active', () => body.data.forEach(venue => pm.expect(venue.status).to.eql('ACTIVE')));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/venues?status=ACTIVE"
          }
        },
        {
          "name": "Get venue detail publicly",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('venue detail returns 200', () => pm.response.to.have.status(200));",
                  "pm.test('fixture venue id matches', () => pm.expect(body.data.id).to.eql('4001'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/venues/4001"
          }
        },
        {
          "name": "Reject USER venue creation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('USER create returns 403', () => pm.response.to.have.status(403));",
                  "pm.test('forbidden code is stable', () => pm.expect(body.code).to.eql('AUTH_FORBIDDEN'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"USER cannot create this venue\",\n  \"category\": \"TEA_SHOP\",\n  \"description\": \"permission check\",\n  \"addressText\": \"mock address\",\n  \"queueEnabled\": true,\n  \"bookingEnabled\": false,\n  \"defaultPrice\": 0.00\n}"
            },
            "url": "{{baseUrl}}/api/v1/venues"
          }
        },
        {
          "name": "Login merchant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('merchant login returns 200', () => pm.response.to.have.status(200));",
                  "pm.test('merchant role is returned', () => pm.expect(body.data.user.role).to.eql('MERCHANT'));",
                  "pm.environment.set('merchantToken', body.data.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"merchant_tea\",\n  \"password\": \"Merchant123456\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        },
        {
          "name": "Create merchant-owned venue",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('venueName', 'Postman Venue ' + Date.now());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('merchant create returns 201', () => pm.response.to.have.status(201));",
                  "pm.test('created venue belongs to merchant fixture', () => pm.expect(body.data.merchantId).to.eql('2001'));",
                  "pm.test('new venue is active', () => pm.expect(body.data.status).to.eql('ACTIVE'));",
                  "pm.environment.set('venueId', body.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{merchantToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{venueName}}\",\n  \"category\": \"STUDY_ROOM\",\n  \"description\": \"created by Postman\",\n  \"addressText\": \"Postman mock address\",\n  \"queueEnabled\": false,\n  \"bookingEnabled\": true,\n  \"defaultPrice\": 12.50,\n  \"merchantId\": 2002\n}"
            },
            "url": "{{baseUrl}}/api/v1/venues"
          }
        },
        {
          "name": "Update owned venue",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('merchant update returns 200', () => pm.response.to.have.status(200));",
                  "pm.test('venue name is updated', () => pm.expect(body.data.name).to.eql(pm.collectionVariables.get('venueName') + ' Updated'));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{merchantToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{venueName}} Updated\",\n  \"category\": \"STUDY_ROOM\",\n  \"description\": \"updated by Postman\",\n  \"addressText\": \"Updated mock address\",\n  \"queueEnabled\": false,\n  \"bookingEnabled\": true,\n  \"defaultPrice\": 15.00\n}"
            },
            "url": "{{baseUrl}}/api/v1/venues/{{venueId}}"
          }
        },
        {
          "name": "Disable owned venue",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('merchant status update returns 200', () => pm.response.to.have.status(200));",
                  "pm.test('venue is inactive', () => pm.expect(body.data.status).to.eql('INACTIVE'));"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{merchantToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"INACTIVE\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/venues/{{venueId}}/status"
          }
        },
        {
          "name": "Reject missing venue detail",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('missing venue returns 404', () => pm.response.to.have.status(404));",
                  "pm.test('not found code is stable', () => pm.expect(body.code).to.eql('VENUE_NOT_FOUND'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/venues/999999999"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "registerUsername",
      "value": ""
    },
    {
      "key": "venueName",
      "value": ""
    }
  ]
}
