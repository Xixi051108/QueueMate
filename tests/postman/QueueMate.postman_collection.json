    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create free booking slot",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const now = Math.floor(Date.now() / 1000);",
                  "const date = new Date();",
                  "date.setUTCDate(date.getUTCDate() + 30 + (now % 300));",
                  "const second = String(now % 59).padStart(2, '0');",
                  "pm.collectionVariables.set('bookingSlotDate', date.toISOString().slice(0, 10));",
                  "pm.collectionVariables.set('freeSlotStartTime', `14:00:${second}`);",
                  "pm.collectionVariables.set('freeSlotEndTime', `15:00:${second}`);",
                  "pm.collectionVariables.set('paidSlotStartTime', `16:00:${second}`);",
                  "pm.collectionVariables.set('paidSlotEndTime', `17:00:${second}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('free slot create returns 201', () => pm.response.to.have.status(201));",
                  "pm.test('free slot is open and empty', () => { pm.expect(body.data.price).to.eql(0.00); pm.expect(body.data.status).to.eql('OPEN'); pm.expect(body.data.reservedCount).to.eql(0); });",
                  "pm.collectionVariables.set('freeSlotId', body.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{merchantToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"slotDate\": \"{{bookingSlotDate}}\",\n  \"startTime\": \"{{freeSlotStartTime}}\",\n  \"endTime\": \"{{freeSlotEndTime}}\",\n  \"capacity\": 2,\n  \"price\": 0.00\n}"
            },
            "url": "{{baseUrl}}/api/v1/venues/4002/slots"
          }
        },
        {
          "name": "Create paid booking slot",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('paid slot create returns 201', () => pm.response.to.have.status(201));",
                  "pm.test('paid slot keeps configured price', () => pm.expect(body.data.price).to.eql(10.00));",
                  "pm.collectionVariables.set('paidSlotId', body.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{merchantToken}}",
                "type": "text"
              }
