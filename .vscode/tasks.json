{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "backend: test",
      "type": "shell",
      "command": "mvn",
      "args": [
        "test"
      ],
      "options": {
        "cwd": "${workspaceFolder}/backend/queuemate-server",
        "env": {
          "DB_PASSWORD": "${input:dbPassword}"
        }
      },
      "group": "test",
      "problemMatcher": "$maven"
    },
    {
      "label": "backend: run",
      "type": "shell",
      "command": "mvn",
      "args": [
        "spring-boot:run"
      ],
      "options": {
        "cwd": "${workspaceFolder}/backend/queuemate-server"
      },
      "group": "build",
      "problemMatcher": "$maven"
    }
  ],
  "inputs": [
    {
      "id": "dbPassword",
      "type": "promptString",
      "description": "QueueMate 本机 MySQL 密码",
      "password": true
    }
  ]
}
