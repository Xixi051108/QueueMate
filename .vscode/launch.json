{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Debug QueueMate Server",
      "request": "launch",
      "mainClass": "com.queuemate.QueueMateApplication",
      "projectName": "queuemate-server",
      "cwd": "${workspaceFolder}/backend/queuemate-server",
      "env": {
        "DB_PASSWORD": "${input:dbPassword}"
      }
    }
  ],
  "inputs": [
    {
      "id": "dbPassword",
      "type": "promptString",
      "description": "QueueMate 本机 MySQL 密码",
      "password": true
    }
  ]
}
